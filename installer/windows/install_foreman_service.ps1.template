# Foreman Windows service installer (PowerShell).
#
# Wraps the foreman gateway as a Windows service via NSSM. NSSM is cleaner
# than sc.exe for hosting Python entry points and gives us proper service
# lifecycle (start / stop / log rotation).
#
# Generated by `foreman install --target windows`. Run as Administrator.
#
# Prereqs:
#   - NSSM installed and on PATH (https://nssm.cc/)
#   - Foreman installed in a venv at {{ install_dir }}\.venv
#   - {{ env_file_path }} populated with ANTHROPIC_API_KEY etc.

$ErrorActionPreference = "Stop"

$ServiceName  = "Foreman"
$DisplayName  = "Foreman quoting agent"
$Description  = "Foreman quoting deputy. See https://github.com/ctmmit/foreman"
$InstallDir   = "{{ install_dir }}"
$ForemanExe   = Join-Path $InstallDir ".venv\Scripts\foreman.exe"
$WorkspaceDir = "{{ workspace_dir }}"
$PolicyTarget = "{{ policy_target }}"
$EnvFile      = "{{ env_file_path }}"

# Log paths
$LogDir = Join-Path $env:ProgramData "Foreman\logs"
New-Item -ItemType Directory -Path $LogDir -Force | Out-Null
$StdoutLog = Join-Path $LogDir "foreman.out.log"
$StderrLog = Join-Path $LogDir "foreman.err.log"

# Stop and remove an existing service if present.
$existing = Get-Service -Name $ServiceName -ErrorAction SilentlyContinue
if ($existing) {
    Write-Host "Stopping and removing existing $ServiceName service..."
    nssm stop $ServiceName confirm
    nssm remove $ServiceName confirm
}

Write-Host "Installing $ServiceName via NSSM..."
nssm install $ServiceName $ForemanExe gateway
nssm set $ServiceName DisplayName $DisplayName
nssm set $ServiceName Description $Description
nssm set $ServiceName AppDirectory $InstallDir
nssm set $ServiceName AppStdout $StdoutLog
nssm set $ServiceName AppStderr $StderrLog
nssm set $ServiceName AppRotateFiles 1
nssm set $ServiceName AppRotateBytes 10485760  # rotate at 10MB
nssm set $ServiceName Start SERVICE_AUTO_START

# Environment: NSSM AppEnvironmentExtra adds to the service env without
# clobbering inherited variables.
nssm set $ServiceName AppEnvironmentExtra `
    "FOREMAN_POLICY_TARGET=$PolicyTarget" `
    "FOREMAN_ENV_FILE=$EnvFile"

Write-Host "Starting $ServiceName..."
nssm start $ServiceName

Write-Host ""
Write-Host "Foreman service installed and started."
Write-Host "  - Logs:        $LogDir"
Write-Host "  - Workspace:   $WorkspaceDir"
Write-Host "  - Env file:    $EnvFile"
Write-Host "  - Policy:      $PolicyTarget"
Write-Host ""
Write-Host "Manage with: nssm start|stop|restart|status Foreman"
